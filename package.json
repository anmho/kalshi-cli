{
  "name": "@anmho/kalshi-cli",
  "version": "0.2.2",
  "description": "Curated terminal-first CLI for Kalshi using the official TypeScript SDK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anmho/kalshi-cli.git"
  },
  "homepage": "https://github.com/anmho/kalshi-cli#readme",
  "bugs": {
    "url": "https://github.com/anmho/kalshi-cli/issues"
  },
  "type": "module",
  "bin": {
    "kalshi": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths && chmod +x dist/index.js",
    "check": "tsc -p tsconfig.build.json --noEmit",
    "test": "bun test ./src/**/*.test.ts",
    "install:system": "bun run build && bun link",
    "uninstall:system": "bun unlink",
    "test:commands": "bun run scripts/test-commands.ts",
    "test:commands:private": "bun run scripts/test-commands-private.ts",
    "docs:sync-openapi": "curl -sSL https://docs.kalshi.com/openapi.yaml -o docs/openapi.yaml",
    "docs:dev": "npm --prefix website run start",
    "docs:build": "npm --prefix website run build",
    "docs:validate": "npm --prefix website run build",
    "release": "bun run check && bun run build && npm publish --access public --cache /tmp/npm-cache"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/columnify": "^1.5.4",
    "@types/node": "^25.6.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "columnify": "^1.6.0",
    "commander": "^14.0.3",
    "dotenv": "^16.6.1",
    "kalshi-typescript": "^3.12.0",
    "zod": "^4.3.6"
  }
}
